          ColWidths[3] := 60; //mag
          ColWidths[4] := 100; //c14age
          ColWidths[5] := 100; //c14age_sig
          ColWidths[6] := 90; //d13c
          ColWidths[7] := 30;
          for m := 0 to FieldCount - 1 do
          begin
            Cells[m, 0] := Fields[m].DisplayName;
          end;
          First;
          while not Eof do
          begin
            for m := 0 to 3 do
            begin
              s := Fields[m].AsString;
              Cells[m, RecNo] := s;
            end;
            s := cells[0, 1];
            for m := 4 to 5 do
            begin
              s := Fields[m].AsString;
              if Length(s) > 0 then
