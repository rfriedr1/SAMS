procedure TfrmMAMS.grdPreviewSamplesDragOver(Sender, Source: TObject; X,
  Y: Integer; State: TDragState; var Accept: Boolean);
var
  c, r: Integer;
begin
  grdPreviewSamples.MouseToCell(x, y, c, r);
  case DragSource of
    drgFraction: Accept := (c = FractionCol);
