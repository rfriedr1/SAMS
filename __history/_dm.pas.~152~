procedure Tdm.StrToClipBoard(const s: string; msDelay: integer);
CONST
   MaxRetries= 5;
VAR
  RetryCount: Integer;
begin
 for RetryCount:= 1 to MaxRetries DO
  TRY
    Clipboard.AsText:= s;
    Break;
  EXCEPT
    on Exception DO
      if RetryCount = MaxRetries then
         RAISE Exception.Create('Cannot set clipboard')
      else
         Sleep(msDelay*RetryCount)
  END;
end;

